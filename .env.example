# .env.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to ".env" and fill in your actual values.
# NEVER commit ".env" to git — add it to .gitignore!
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Get this from MongoDB Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/jobandu?retryWrites=true&w=majority
DB_NAME=jobandu

# ── Amazon S3 ─────────────────────────────────────────────────────────────────
# Create an IAM user in AWS with S3 permissions and get these from the console
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY
AWS_REGION=eu-central-1
S3_BUCKET_NAME=jobandu-cvs

# ── Gmail SMTP ────────────────────────────────────────────────────────────────
# Use an App Password (NOT your real Gmail password!)
# myaccount.google.com → Security → App passwords
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Admin Credentials ─────────────────────────────────────────────────────────
# Used for the /api/admin/* routes (HTTP Basic Auth)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend URLs (no trailing slashes)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://jobandu.dk
